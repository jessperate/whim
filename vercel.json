{
  "crons": [
    {
      "path": "/api/pulse?refresh=1",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/oddities?refresh=1",
      "schedule": "0 5 * * 1"
    },
    {
      "path": "/api/book?refresh=1",
      "schedule": "0 5 * * 2"
    }
  ],
  "rewrites": [
    {
      "source": "/p/:id",
      "destination": "/api/p?id=:id"
    },
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    }
  ]
}
